# Required for trading (not needed for read-only scanning)
POLYMARKET_PRIVATE_KEY=
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY=

# For LLM-assisted market matching
ANTHROPIC_API_KEY=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord alerts (optional)
DISCORD_WEBHOOK_URL=

# Stripe payment (optional, for paid tier)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Absolute base URL used to build Stripe Checkout success/cancel redirects.
# Must be absolute (http:// or https://). Leaving this at localhost in
# production means users will be redirected back to localhost after paying.
ARBSCANNER_PUBLIC_URL=http://localhost:8000

# Web dashboard
ARBSCANNER_SECRET_KEY=change-me-to-a-random-string

# Tier gating: "pro" (default) unlocks the full dashboard, real-time
# alerts, and calibration context. "free" enforces the landing-page
# free-tier caps: top 3 opportunities, 5-minute delayed view, no
# Telegram/Discord alerts, and no calibration context.
ARBSCANNER_TIER=pro

# Sportsbook fair value for sports markets (optional)
# Supports multiple backends: odds-api-io (100 req/hr free),
# the-odds-api (500 req/month free), oddspapi (no stated cap).
# Set ODDS_PROVIDER to choose; defaults to the-odds-api.
ODDS_API_KEY=
ODDS_PROVIDER=the-odds-api
